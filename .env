# Copy to .env and fill in values

# Server
PORT=4000

# MongoDB (same as Next.js app)
MONGODB_URI=mongodb://localhost:27017/MidasWay
# Or Atlas: mongodb+srv://user:pass@cluster.mongodb.net/midas?retryWrites=true&w=majority

# Firebase Admin (verify ID tokens + optional Firestore sync)
# Paste minified service account JSON as one line
FIREBASE_SERVICE_ACCOUNT_JSON=

# Stripe (same keys as website)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# When set, Express also syncs quotes to Firestore (same logic as Next.js).
