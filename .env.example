# Copy to .env – never commit real secrets.

PORT=4000

# MongoDB (required – same DB as midas_admin for shared companies, agents, quotes)
MONGODB_URI=mongodb://localhost:27017/MidasWay

# JWT for AppUser auth (mobile app)
JWT_SECRET=your-secret-key

# Optional: Firebase Admin (verify tokens, Firestore sync)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional: Stripe
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
